# ── MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=darkpattern

# ── Redis / Celery ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Pinecone (leave blank to use local ChromaDB) ───────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=darkpattern-clauses

# ── ChromaDB (local vector DB fallback) ───────────────────
USE_LOCAL_VECTOR_DB=true
CHROMA_PERSIST_DIR=./chroma_db

# ── AWS S3 (leave blank to use local storage) ─────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=darkpattern-screenshots

# ── Local storage fallback ─────────────────────────────────
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_DIR=./local_storage

# ── ML Model paths ─────────────────────────────────────────
NLP_MODEL_PATH=../ml/weights/nlp_model
CV_MODEL_PATH=../ml/weights/cv_model

# ── Score fusion weights ───────────────────────────────────
NLP_WEIGHT=0.6
CV_WEIGHT=0.4

# ── Admin dev token ────────────────────────────────────────
ADMIN_API_KEY=dev-secret-change-me

# ── App settings ──────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","chrome-extension://*"]
JWT_SECRET=super-secret-key-change-me
